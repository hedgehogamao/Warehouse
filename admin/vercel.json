{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://warehouse-production-d396.up.railway.app/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://warehouse-production-d396.up.railway.app/uploads/:path*"
    }
  ]
}

