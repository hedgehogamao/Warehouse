/* 首页样式 */

.welcome {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  text-align: center;
  padding: 60rpx 24rpx;
}

.welcome .title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.welcome .subtitle {
  display: block;
  font-size: 28rpx;
  opacity: 0.8;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
}

.categories {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-item {
  background: #f0f2f5;
  padding: 16rpx 32rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #606266;
}
