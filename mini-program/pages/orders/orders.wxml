<view class="container">
  <view class="order-card" wx:for="{{orders}}" wx:key="id">
    <view class="order-header">
      <text class="order-no">{{item.orderNo}}</text>
      <text class="order-status {{item.status === 'PAID' ? 'paid' : 'refunded'}}">
        {{item.status === 'PAID' ? '已支付' : '已退款'}}
      </text>
    </view>
    <view class="order-items">
      <view class="order-item" wx:for="{{item.items}}" wx:for-item="it" wx:key="productName">
        <text class="item-name">{{it.productName}}</text>
        <text class="item-qty">x{{it.quantity}}</text>
        <text class="item-price">¥{{it.subtotal}}</text>
      </view>
    </view>
    <view class="order-footer">
      <text class="order-date">{{item.createdAt}}</text>
      <text class="order-total">合计: ¥{{item.totalAmount}}</text>
    </view>
  </view>

  <view class="loading-tip" wx:if="{{loading}}">加载中...</view>
  <view class="loading-tip" wx:if="{{noMore && orders.length > 0}}">没有更多了</view>
  <view class="empty-tip" wx:if="{{!loading && orders.length === 0}}">暂无购买记录</view>
</view>
