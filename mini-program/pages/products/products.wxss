.container { padding: 24rpx; background: #faf9f5; min-height: 100vh; }
.search-bar { margin-bottom: 24rpx; }
.search-input { background: #efe9de; border-radius: 12rpx; padding: 16rpx 24rpx; font-size: 28rpx; }
.product-list { display: flex; flex-direction: column; gap: 16rpx; }
.product-card { background: #fff; border-radius: 12rpx; border: 1rpx solid #e6dfd8; overflow: hidden; }
.product-main { display: flex; padding: 20rpx; }
.product-img { width: 160rpx; height: 160rpx; border-radius: 8rpx; background: #efe9de; margin-right: 20rpx; flex-shrink: 0; }
.product-info { flex: 1; display: flex; flex-direction: column; justify-content: space-between; }
.product-name { font-size: 28rpx; font-weight: 500; color: #141413; }
.product-meta { font-size: 24rpx; color: #8e8b82; margin-top: 4rpx; }
.product-bottom { display: flex; justify-content: space-between; align-items: center; }
.product-price { font-size: 32rpx; font-weight: 600; color: #cc785c; }
.stock-tag { font-size: 22rpx; color: #5db872; }
.stock-tag.out { color: #c64545; }
.stock-tag.low { color: #d4a017; }
.add-cart-btn { background: #cc785c; color: #fff; text-align: center; padding: 14rpx; font-size: 26rpx; font-weight: 500; }
.loading-tip { text-align: center; color: #8e8b82; padding: 24rpx; font-size: 24rpx; }
.empty-tip { text-align: center; color: #8e8b82; padding: 120rpx 0; font-size: 28rpx; }
