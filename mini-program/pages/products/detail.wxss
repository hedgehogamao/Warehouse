.container { background: #faf9f5; min-height: 100vh; padding-bottom: 120rpx; }
.product-image { width: 100%; height: 500rpx; background: #efe9de; }
.info-section { padding: 24rpx; background: #fff; margin-bottom: 16rpx; }
.product-name { font-size: 34rpx; font-weight: 600; color: #141413; margin-bottom: 12rpx; }
.product-price { font-size: 40rpx; font-weight: 600; color: #cc785c; margin-bottom: 8rpx; }
.stock-status { font-size: 24rpx; color: #5db872; }
.stock-status.out { color: #c64545; }
.stock-status.low { color: #d4a017; }
.detail-section { padding: 24rpx; background: #fff; margin-bottom: 16rpx; }
.detail-row { display: flex; padding: 12rpx 0; border-bottom: 1rpx solid #ebe6df; }
.detail-row:last-child { border-bottom: none; }
.detail-label { width: 120rpx; color: #8e8b82; font-size: 28rpx; flex-shrink: 0; }
.detail-value { flex: 1; color: #141413; font-size: 28rpx; }
.desc-section { padding: 24rpx; background: #fff; }
.desc-title { font-size: 30rpx; font-weight: 600; color: #141413; margin-bottom: 12rpx; }
.desc-content { font-size: 28rpx; color: #3d3d3a; line-height: 1.6; }
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; display: flex; background: #fff; border-top: 1rpx solid #e6dfd8; }
.go-cart { flex: 1; text-align: center; padding: 24rpx; font-size: 28rpx; color: #3d3d3a; }
.add-cart { flex: 2; text-align: center; padding: 24rpx; font-size: 30rpx; font-weight: 500; background: #cc785c; color: #fff; }
.add-cart.disabled { background: #e6dfd8; color: #8e8b82; }
.loading { text-align: center; padding: 120rpx; color: #8e8b82; }
