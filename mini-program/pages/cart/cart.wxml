<view class="container">
  <view wx:if="{{cart.length > 0}}">
    <view class="cart-header">
      <text>{{t.itemCount.replace('{count}', totalCount)}}</text>
      <text class="clear-btn" bindtap="onClear">{{t.clear}}</text>
    </view>
    <view class="cart-item" wx:for="{{cart}}" wx:key="id">
      <view class="item-info">
        <view class="item-name">{{item.name}}</view>
        <view class="item-sku">{{item.sku}}</view>
        <view class="item-price">¥{{item.salePrice}}</view>
      </view>
      <view class="item-actions">
        <view class="qty-btn" data-index="{{index}}" data-action="minus" bindtap="onQuantityChange">-</view>
        <text class="qty-num">{{item.quantity}}</text>
        <view class="qty-btn" data-index="{{index}}" data-action="plus" bindtap="onQuantityChange">+</view>
        <view class="delete-btn" data-index="{{index}}" bindtap="onDelete">{{t.clear === '清空' ? '删除' : 'Eliminar'}}</view>
      </view>
      <view class="item-subtotal">{{t.subtotal}}: ¥{{item.salePrice * item.quantity}}</view>
    </view>
    <view class="total-section">
      <text class="total-label">{{t.total}}</text>
      <text class="total-amount">¥{{total}}</text>
    </view>
    <view class="tip-section">
      <view class="tip-text">{{t.tip1}}</view>
      <view class="tip-text">{{t.tip2}}</view>
    </view>
    <view class="contact-btn" bindtap="onContactStore">{{t.contactStore}}</view>
  </view>
  <view wx:else class="empty-cart">
    <text class="empty-icon">{{t.emptyIcon}}</text>
    <text class="empty-text">{{t.emptyText}}</text>
    <navigator url="/pages/products/products" open-type="switchTab" class="go-shop">{{t.goShop}}</navigator>
  </view>
</view>
